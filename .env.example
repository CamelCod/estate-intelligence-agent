# ── Telegram Bot ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://estate_user:yourpassword@localhost:5432/estate_intelligence

# ── n8n Webhooks ──────────────────────────────────────────────────────────────
N8N_ONBOARD_WEBHOOK=http://localhost:5678/webhook/customer-onboarded
N8N_QA_WEBHOOK=http://localhost:5678/webhook/cctv-qa

# ── LLM ───────────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=your_openrouter_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key

# ── Stripe Billing ────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_starter_placeholder
STRIPE_PRICE_STANDARD=price_standard_placeholder
STRIPE_PRICE_ESTATE=price_estate_placeholder

# ── App ───────────────────────────────────────────────────────────────────────
BASE_URL=https://yourdomain.com
FLASK_ENV=production

# ── Camera Agent (laptop CCTV) ────────────────────────────────────────────────
# Vision backend: "reka" (default) | "claude" | "auto" (reka→claude fallback)
VISION_BACKEND=reka

# HuggingFace token — get free token at https://huggingface.co/settings/tokens
# Required for Reka Edge 2603 inference. Read-only token is sufficient.
HF_TOKEN=hf_...

# Camera settings (optional — sensible defaults built in)
CAMERA_DEVICE=0               # webcam device index (0 = built-in laptop cam)
MOTION_THRESHOLD=0.015        # fraction of pixels that must change (1.5%)
CAPTURE_COOLDOWN=5.0          # minimum seconds between captures
LOCATION_LABEL=Home / Office  # shown in dashboard and Telegram alerts
OWNER_CONTEXT=UAE villa owner monitoring their home
TELEGRAM_CHAT_ID=your_telegram_chat_id   # optional — for alert notifications