# ── Telegram Bot ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://estate_user:yourpassword@localhost:5432/estate_intelligence

# ── n8n Webhooks ──────────────────────────────────────────────────────────────
N8N_ONBOARD_WEBHOOK=http://localhost:5678/webhook/customer-onboarded
N8N_QA_WEBHOOK=http://localhost:5678/webhook/cctv-qa

# ── LLM ───────────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=your_openrouter_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key

# ── Stripe Billing ────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_starter_placeholder
STRIPE_PRICE_STANDARD=price_standard_placeholder
STRIPE_PRICE_ESTATE=price_estate_placeholder

# ── App ───────────────────────────────────────────────────────────────────────
BASE_URL=https://yourdomain.com
FLASK_ENV=production